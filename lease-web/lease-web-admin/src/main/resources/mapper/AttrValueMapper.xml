<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tc.lease.web.admin.mapper.AttrValueMapper">

    <update id="deleteByAttrKeyId">
        update attr_value
        set is_deleted = 1
        where attr_key_id = #{attrKeyId}
    </update>
</mapper>
