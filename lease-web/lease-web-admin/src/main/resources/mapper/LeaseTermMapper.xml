<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tc.lease.web.admin.mapper.LeaseTermMapper">

    <select id="listLeaseTermByRoomId" resultType="com.tc.lease.model.entity.LeaseTerm">
        SELECT
            id,
            month_count,
            unit
        FROM
            lease_term
        WHERE
            id  IN (
                SELECT
                    lease_term_id
                FROM
                    room_lease_term
                WHERE
                    room_id = #{roomId}
                and is_deleted = 0
            )
      and is_deleted = 0
    </select>
</mapper>
